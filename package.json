{
  "name": "coverly",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.x",
    "pnpm": "10.x"
  },
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build:packages",
    "dev:mobile": "turbo run dev:mobile --filter=@coverly/mobile",
    "dev:api": "turbo run dev:api --filter=@coverly/api",
    "start": "turbo run start --filter=@coverly/api",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate",
    "db:migrate:dev": "turbo run db:migrate:dev",
    "db:migrate:deploy": "turbo run db:migrate:deploy",
    "db:push": "turbo run db:push --filter=@coverly/db",
    "db:seed": "turbo run db:seed --filter=@coverly/db",
    "db:studio": "turbo run db:studio --filter=@coverly/db",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@coverly/eslint-config": "workspace:*",
    "@coverly/typescript-config": "workspace:*",
    "rimraf": "6.1.3",
    "eslint": "9.39.1",
    "prettier": "3.7.4",
    "turbo": "2.7.6",
    "typescript": "5.9.3"
  }
}
