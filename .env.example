# Split across env files as needed: apps/api/.env (API + Prisma), apps/mobile/.env (Expo inlines EXPO_PUBLIC_*).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coverly"
PORT=8082
# Replace 192.168.x.x with your computer's LAN IP (Expo Go on a phone cannot use localhost).
EXPO_PUBLIC_API_URL="http://192.168.1.42:8082"
BETTER_AUTH_URL="http://192.168.1.42:8082"
BETTER_AUTH_SECRET="replace-with-32-plus-char-secret"
