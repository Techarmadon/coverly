{
  "name": "@coverly/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev:api": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run"
  },
  "dependencies": {
    "@coverly/auth": "workspace:*",
    "@coverly/db": "workspace:*",
    "@coverly/orpc": "workspace:*",
    "@hono/node-server": "1.19.4",
    "@orpc/openapi": "1.9.2",
    "@orpc/server": "1.9.2",
    "hono": "4.9.6",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@coverly/eslint-config": "workspace:*",
    "@coverly/typescript-config": "workspace:*",
    "@types/node": "24.6.0",
    "eslint": "9.39.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
