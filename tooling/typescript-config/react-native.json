{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": [
      "ES2022"
    ],
    "types": [
      "react",
      "react-native"
    ],
    "allowImportingTsExtensions": false
  }
}
